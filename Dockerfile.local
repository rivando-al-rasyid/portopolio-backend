# Local development Dockerfile.
# This intentionally runs Payload/Next in development mode so Payload's
# Postgres adapter can use Drizzle push mode and create/update the tables.
FROM node:22-alpine

WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1

RUN apk add --no-cache libc6-compat

COPY package*.json ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

COPY . .

EXPOSE 3000
CMD ["npm", "run", "dev:docker"]
