# Domain setup
# Cloud mode expects these DNS records to point to your server:
#   portfolio.example.com -> server IP
#   n8n.example.com       -> server IP
DOMAIN_NAME=example.com
APP_SUBDOMAIN=portfolio
N8N_SUBDOMAIN=n8n
SSL_EMAIL=you@example.com
GENERIC_TIMEZONE=Asia/Jakarta

# Public URLs
# PAYLOAD_PUBLIC_SERVER_URL is the public URL of this Payload dashboard/API.
# FRONTEND_ORIGIN is your separate portfolio frontend origin. Do not add trailing slashes.
PAYLOAD_PUBLIC_SERVER_URL=https://portfolio.example.com
NEXT_PUBLIC_SITE_URL=https://portfolio.example.com
FRONTEND_ORIGIN=http://localhost:5173
N8N_EDITOR_BASE_URL=https://n8n.example.com

# Local fallback ports. Traefik uses 80/443 in cloud mode.
PAYLOAD_LOCAL_PORT=3000
N8N_LOCAL_PORT=5678

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DEFAULT_DB=postgres
PAYLOAD_DB_NAME=payload
N8N_DB_NAME=n8n

# Payload / autoshare
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=change-this-payload-secret
AUTOSHARE_WEBHOOK_SECRET=change-this-autoshare-secret

# n8n
# Generate with: openssl rand -base64 32
# Keep this value forever. Changing it can break existing n8n credentials.
N8N_ENCRYPTION_KEY=change-this-n8n-encryption-key
