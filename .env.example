# Payload uses a direct Postgres connection string, not the Supabase publishable key.
# Supabase format usually needs sslmode=require.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# Generate a long random value. Example: openssl rand -base64 32
PAYLOAD_SECRET=replace-this-with-a-long-random-secret

# Optional secret for n8n / cron jobs that update autoshare status.
AUTOSHARE_WEBHOOK_SECRET=replace-this-for-n8n

# Public URL of this Payload dashboard/API.
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Your separate portfolio frontend origin. Do not add a trailing slash.
FRONTEND_ORIGIN=http://localhost:5173
