# Public DNS / Caddy HTTPS
PUBLIC_HOST=202-155-132-98.domainesia.io
SSL_EMAIL=your-email@example.com

# Frontend image config
FRONTEND_IMAGE=ghcr.io/rivando-al-rasyid/portopolio-astro:latest
# Use 80 if the image uses Nginx. Use 4321 if the image runs Astro Node directly.
FRONTEND_CONTAINER_PORT=80

# Postgres
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DEFAULT_DB=n8n
PAYLOAD_DB_NAME=payload
N8N_DB_NAME=n8n

# App secrets
PAYLOAD_SECRET=change_this_payload_secret_at_least_32_chars
AUTOSHARE_WEBHOOK_SECRET=change_this_autoshare_secret_at_least_32_chars
N8N_ENCRYPTION_KEY=change_this_to_random_32_char_string

GENERIC_TIMEZONE=Asia/Jakarta
