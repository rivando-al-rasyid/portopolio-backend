{
  email {$SSL_EMAIL}
}

{$PUBLIC_HOST} {
  encode gzip zstd

  @payload_admin path /admin /admin/*
  @payload_api path /api /api/* /graphql /graphql/* /_next/* /media/*
  @n8n path /n8n /n8n/*

  handle @payload_admin {
    reverse_proxy payload:3000
  }

  handle @payload_api {
    reverse_proxy payload:3000
  }

  # n8n is served under /n8n/ on the same public host.
  # Keep the /n8n prefix because N8N_PATH=/n8n/ is set in compose.yaml.
  handle @n8n {
    reverse_proxy n8n:5678
  }

  # Everything else goes to the public Astro frontend image.
  handle {
    reverse_proxy frontend:{$FRONTEND_CONTAINER_PORT}
  }
}
